# =============================================================================
# AI Shared Services — MCP Environment Variables
# =============================================================================
# Copy this file to mcps/.env and fill in your values.
# The .env file is gitignored and must never be committed.
#
# Each MCP server reads only the variables it needs — you don't have to
# set all of them if you're only running one or two MCPs.
# =============================================================================

# --- Jira MCP (mcps/jira/server.py) -----------------------------------------
# Your Atlassian organization URL
JIRA_SERVER=https://yourorg.atlassian.net

# Atlassian API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-atlassian-api-token-here

# Email address associated with the API token
JIRA_EMAIL=you@yourorg.com

# --- Confluence MCP (mcps/confluence/server.py) ------------------------------
# Confluence base URL (include /wiki for Atlassian Cloud)
CONFLUENCE_URL=https://yourorg.atlassian.net/wiki

# Email address of the service account (can be same as JIRA_EMAIL)
CONFLUENCE_USERNAME=you@yourorg.com

# Atlassian API token (can be same token as JIRA_API_TOKEN)
CONFLUENCE_API_TOKEN=your-atlassian-api-token-here

# --- GitHub MCP (mcps/github/server.ts) --------------------------------------
# Fine-grained personal access token or GitHub App installation token.
# Minimum required read-only permissions:
#   - Contents (read)
#   - Pull requests (read)
#   - Actions (read, for CI status)
# Scope the token to only the repos this team works in — not the whole org.
GITHUB_TOKEN=your-github-token-here
